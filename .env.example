# Swedeb API - Environment Variables
#
# Copy this file to .env and fill in values appropriate for your environment.
# For local development (no Redis/Celery), use config/debug.config.yml which
# sets celery_enabled: false and use_multiprocessing: false automatically.
#
# Usage:
#   cp .env.example .env
#   export SWEDEB_CONFIG_PATH=config/debug.config.yml   # local dev (no Redis)
#   export SWEDEB_CONFIG_PATH=config/config.yml          # production / staging


# ---------------------------------------------------------------------------
# Core application configuration
# ---------------------------------------------------------------------------

# Path to the YAML configuration file read at startup by the API process and
# by the Celery worker (via the worker_init signal).
# Defaults to config/config.yml when not set.
SWEDEB_CONFIG_PATH=config/config.yml

# ---------------------------------------------------------------------------
# Corpus and data paths
# These are normally set via config.yml; override here only when needed.
# ---------------------------------------------------------------------------

# Root directory for CWB corpus registry files.
# CORPUS_REGISTRY=/data/v1.4.1/cwb/registry

# Metadata SQLite database path.
# METADATA_FILENAME=/data/metadata/riksprot_metadata.v1.1.3.db

# Feather speech-index directory.
# TAGGED_CORPUS_FOLDER=/data/v1.4.1/speeches

# Bootstrap corpus folder (pre-built speech index).
# FOLDER=/data/v1.4.1/speeches/bootstrap_corpus

# Corpus tag / version label.
# TAG=v1.4.1

# ---------------------------------------------------------------------------
# KWIC / CWB settings
# ---------------------------------------------------------------------------

# Name of the CWB corpus used for KWIC queries.
# KWIC_CORPUS_NAME=RIKSPROT_V141_TEST

# Directory that contains the CWB data files for KWIC.
# KWIC_DIR=/data/v1.4.1/cwb/data

# ---------------------------------------------------------------------------
# Redis (production / Celery mode only)
# Required when config.yml has development.celery_enabled: true.
# Not needed for local development with debug.config.yml.
# ---------------------------------------------------------------------------

# Redis connection URL used as Celery broker and result backend.
# Must be reachable from both the API container and the Celery worker container.
# The API container, Celery worker, and Redis container must share the same
# Docker / Podman network and the same KWIC result-cache volume.
# REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Static file serving (optional)
# ---------------------------------------------------------------------------

# Path to the pre-built frontend static files inside the container.
# Defaults to the embedded public/ directory when not set.
# STATIC_DIR=/app/public

# Frontend version tag used by the Docker image entrypoint to download
# frontend assets (main / staging / test).  Usually set as a build arg;
# override here to force a specific version at runtime.
# FRONTEND_VERSION=staging
