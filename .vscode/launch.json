{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "name": "Python: Current File",
            "env": {
                "PYTHONPATH": "${workspaceFolder}${pathSeparator}${env:PYTHONPATH}",
                "PYDEVD_WARN_EVALUATION_TIMEOUT": "10"
            },
            "console": "internalConsole",
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "debugpy",
            "request": "launch",
            "purpose": [
                "debug-test"
            ],
            "name": "PyTest",
            "stopOnEntry": false,
            // "python": "${command:python.interpreterPath}",
            "justMyCode": true,
            // "envFile": "${workspaceRoot}/.venv",
            "cwd": "${workspaceRoot}",
            "console": "internalConsole",
            "redirectOutput": true,
            "args": [
                "-sv"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYDEVD_WARN_EVALUATION_TIMEOUT": "10"
            },
            
        },
        {
            "name": "FastAPI: backend only",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["main:app", "--port", "8000"],
            "jinja": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "SWEDEB_CONFIG_PATH": "config/dev_swedeb.yml"
            }
        },
        {
            "name": "FastAPI: backend + static frontend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["main:app", "--port", "8000"],
            "jinja": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "SWEDEB_CONFIG_PATH": "config/dev_swedeb.yml",
                "STATIC_DIR": "${workspaceFolder}/../swedeb_frontend/dist/spa"
            }
        },
        {
            "name": "FastAPI: backend only with HMR",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["main:app", "--port", "8000", "--reload"],
            "jinja": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "SWEDEB_CONFIG_PATH": "config/dev_swedeb.yml"
            }
        },
        {
            "name": "FastAPI: backend + static frontend with HMR",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["main:app", "--port", "8000", "--reload"],
            "jinja": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "SWEDEB_CONFIG_PATH": "config/dev_swedeb.yml",
                "STATIC_DIR": "${workspaceFolder}/../swedeb_frontend/dist/spa"
            }
        }
    ]
}