# Example environment configuration for decoupled frontend/backend

# Frontend version to download (can be 'latest', a specific tag like 'v1.2.3', or a branch)
FRONTEND_VERSION=latest

# Backend configuration
SWEDEB_PORT=8092
SWEDEB_CONFIG_PATH=/app/config/config.yml
SWEDEB_DATA_FOLDER=/data

# Container configuration
SWEDEB_IMAGE_NAME=ghcr.io/humlab-swedeb/swedeb-api
SWEDEB_IMAGE_TAG=latest
SWEDEB_CONTAINER_NAME=swedeb-api
SWEDEB_ENVIRONMENT=production
SWEDEB_HOST_PORT=8092

# Data configuration
METADATA_VERSION=latest
SWEDEB_METADATA_FILENAME=/path/to/riksprot_metadata.db