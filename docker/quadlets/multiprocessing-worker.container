# Podman Quadlet: Dedicated Celery worker for multiprocessing-capable tasks

[Unit]
Description=Swedeb Multiprocessing Worker
Requires=redis.service
After=redis.service
BindsTo=redis.service
PartOf=redis.service

[Container]
Image=ghcr.io/humlab-swedeb/swedeb-api:staging
ContainerName=swedeb-multiprocessing-worker-staging
Network=swedeb-staging-app.network

# Mount same data volumes as the API container
Volume=%h/data/v1.4.1:/data:ro
Volume=%h/configuration/secrets/config.yml:/app/config/config.yml:ro

# Share the ticket result cache with the API container so results are visible to both
Tmpfs=/tmp:rw,nosuid,nodev,exec,size=1G
Volume=swedeb-kwic-cache:/tmp/swedeb-kwic-cache:rw

# Dedicated solo worker for tasks that need their own multiprocessing pool.
# Queue name must stay aligned with config.yml celery.multiprocessing_queue.
Exec=celery -A api_swedeb.celery_tasks worker --loglevel=info --pool=solo --concurrency=1 --queues=multiprocessing

Environment=SWEDEB_CONFIG_PATH=/app/config/config.yml
EnvironmentFile=%h/configuration/secrets/.env

# Security hardening — mirrors app.container settings
NoNewPrivileges=true
DropCapability=all
ReadOnly=true

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=default.target
